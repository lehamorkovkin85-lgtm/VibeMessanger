rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Внимание: Эти правила разрешают доступ всем (для разработки)
    // В продакшене их нужно будет ограничить
    match /users/{userId} {
      allow read, write: if true;
    }
    match /channels/{channelId} {
      allow read, write: if true;
    }
    match /messages/{messageId} {
      allow read, write: if true;
    }
    match /friendships/{friendshipId} {
      allow read, write: if true;
    }
    
    // Общее правило для остальных коллекций
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
